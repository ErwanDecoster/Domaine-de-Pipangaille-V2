const vectorPath = vectorIcons[normalizedPlatform];
const isStrokeIcon =
  normalizedPlatform === "facebook" || normalizedPlatform === "linkedin";
const classes = ["inline-block", "text-current", className]
  .filter(Boolean)
  .join(" ");
---

{
  vectorPath ? (
    <svg
      class={classes}
      viewBox="0 0 24 24"
      fill={isStrokeIcon ? "none" : "currentColor"}
      stroke={isStrokeIcon ? "currentColor" : undefined}
      stroke-width={isStrokeIcon ? 2 : undefined}
      stroke-linecap={isStrokeIcon ? "round" : undefined}
      stroke-linejoin={isStrokeIcon ? "round" : undefined}
      aria-hidden="true"
      focusable="false"
    >
      <path d={vectorPath} />
    </svg>
  ) : (
    <span class={classes} aria-hidden="true">
      {platform?.slice(0, 1)?.toUpperCase()}
    </span>
  )
}
